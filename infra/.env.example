COMPOSE_PROJECT_NAME=alarmstack
TZ=Asia/Qyzylorda

AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops
POSTGRES_DB=mlops

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_ENDPOINT=http://minio:9000

MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123

MODEL_PROMOTION_MODE=manual
MODEL_PROMOTION_METRIC=f1_anomaly
DATA_DROP_PATH=./data_drop

# Optional image overrides (useful for private mirrors or offline cache)
# Example:
# AIRFLOW_IMAGE=registry.local/apache/airflow:2.10.3-python3.11
# SPARK_IMAGE=registry.local/spark:3.5.8-scala2.12-java17-python3-ubuntu
POSTGRES_IMAGE=docker.io/library/postgres:16
MINIO_IMAGE=docker.io/minio/minio:RELEASE.2025-01-20T14-49-07Z
MINIO_MC_IMAGE=docker.io/minio/mc:RELEASE.2025-03-12T17-29-24Z
AIRFLOW_IMAGE=docker.io/apache/airflow:2.10.3-python3.11
SPARK_IMAGE=docker.io/library/spark:3.5.8-scala2.12-java17-python3-ubuntu
MLFLOW_IMAGE=ghcr.io/mlflow/mlflow:v2.17.2
INFERENCE_BASE_IMAGE=docker.io/tiangolo/uvicorn-gunicorn-fastapi:python3.11
FILE_WATCHER_IMAGE=docker.io/library/alpine:3.20
PROMETHEUS_IMAGE=docker.io/prom/prometheus:v2.54.1
GRAFANA_IMAGE=docker.io/grafana/grafana-oss:11.2.2
SVELTE_UI_IMAGE=docker.io/library/node:20-alpine
NGINX_IMAGE=docker.io/library/nginx:1.27-alpine

# Port exposed by the nginx reverse proxy (UI + /api/* passthrough).
# Must be >= 1024 for rootless Podman (and non-admin Windows).
UI_PORT=8088

# Leave empty in production (nginx handles same-origin routing).
# Set to comma-separated origins only when running inference-api directly, e.g.:
# CORS_ORIGINS=http://localhost:5173
CORS_ORIGINS=
